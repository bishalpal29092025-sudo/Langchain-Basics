# ==========================================
# Dependencies
# ==========================================
node_modules/
jspm_packages/
web_modules/

# ==========================================
# TypeScript & Build Output
# ==========================================
# Ignore the Javascript outputs generated by the TypeScript compiler
dist/
build/
out/
lib/

# Ignore the build cache used for incremental compilation
*.tsbuildinfo

# Ignore source maps if you do not want to track them
*.js.map
*.ts.map

# Avoid committing accidental .js files in source folders if transpiled locally
# (Uncomment the line below if you compile files directly next to your .ts files)
# src/**/*.js

# ==========================================
# Logs & Caches
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

.npm
.eslintcache
.stylelintcache
.prettiercache
.turbo/
.cache/

# ==========================================
# Testing & Coverage
# ==========================================
coverage/
.nyc_output/
junit.xml

# ==========================================
# Environment Variables & Secrets
# ==========================================
.env
.env.development.local
.env.test.local
.env.production.local
*.pem

# ==========================================
# IDEs & Text Editors
# ==========================================
# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# IntelliJ / WebStorm
.idea/

# Visual Studio
.vs/

# Other Editors
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==========================================
# Operating System Files
# ==========================================
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db
